{
  "name": "calculator-client",
  "version": "1.0.0",
  "description": "gRPC client for Calculator service",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "generate": "grpc_tools_node_protoc --js_out=import_style=commonjs,binary:./proto --grpc_out=grpc_js:./proto --proto_path=../proto ../proto/calculator.proto ../proto/kv.proto"
  },
  "dependencies": {
    "@grpc/grpc-js": "^1.10",
    "grpc-tools": "^1.12",
    "google-protobuf": "^3.21"
  }
}
